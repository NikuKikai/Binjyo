<Window x:Class="Binjyo.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="History"
        Width="920"
        Height="700"
        MinWidth="640"
        MinHeight="420"
        Background="#111111"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">
        <DockPanel.Resources>
            <Style TargetType="Button">
                <Setter Property="Background" Value="#FF1E1E1E"/>
                <Setter Property="Foreground" Value="#FFF3F3F3"/>
                <Setter Property="BorderBrush" Value="#FF3C3C3C"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFD6D6D6"/>
            </Style>
        </DockPanel.Resources>
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#FFF3F3F3"
                       Text="History"/>
            <Button Grid.Column="1"
                    Margin="0,0,8,0"
                    Padding="12,6"
                    Click="ClearOldButton_Click"
                    Content="Clear Older Than 1 Week"/>
            <Button Grid.Column="2"
                    Padding="12,6"
                    Click="ClearButton_Click"
                    Content="Clear All"/>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl Name="GroupsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF3F3F3"
                                       Text="{Binding Key}"/>
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,12,12"
                                                Padding="8"
                                                BorderBrush="#FF3C3C3C"
                                                BorderThickness="1"
                                                Background="#FF1E1E1E"
                                                MouseLeftButtonDown="EntryBorder_MouseLeftButtonDown">
                                            <StackPanel Width="180">
                                                <Border Width="164"
                                                        Height="120"
                                                        Background="#FF202020"
                                                        BorderBrush="#FF3C3C3C"
                                                        BorderThickness="1">
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="Uniform"
                                                           Width="164"
                                                           Height="120"/>
                                                </Border>
                                                <TextBlock Margin="0,8,0,0"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFF3F3F3"
                                                           Text="{Binding CreatedAtText}"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="#FFD6D6D6"
                                                           Text="{Binding TransformText}"/>
                                                <TextBlock Margin="0,2,0,0"
                                                           Foreground="#FFD6D6D6"
                                                           Text="{Binding PositionText}"/>
                                                <TextBlock Margin="0,2,0,0"
                                                           Foreground="#FFD6D6D6"
                                                           Text="{Binding DrawingText}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
