<Application x:Class="Binjyo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Binjyo">
    <Application.Resources>
        <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#161616"/>
        <SolidColorBrush x:Key="MenuBorderBrush" Color="#323232"/>
        <SolidColorBrush x:Key="MenuForegroundBrush" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="MenuSecondaryForegroundBrush" Color="#A8A8A8"/>
        <SolidColorBrush x:Key="MenuHoverBrush" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="MenuCheckedBrush" Color="#1F5E3B"/>
        <SolidColorBrush x:Key="MenuDisabledForegroundBrush" Color="#666666"/>
        <SolidColorBrush x:Key="MenuSeparatorBrush" Color="#3A3A3A"/>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="{StaticResource MenuBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource MenuForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource MenuBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ScrollViewer
                                CanContentScroll="True"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Disabled">
                                <ItemsPresenter Margin="{TemplateBinding Padding}" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1" Background="{StaticResource MenuSeparatorBrush}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DarkMenuItemTemplate" TargetType="{x:Type MenuItem}">
            <Border x:Name="RootBorder" Background="Transparent" CornerRadius="8" SnapsToDevicePixels="True">
                <Grid Margin="2,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="18"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="CheckContainer" Grid.Column="0" Width="18" Height="18" CornerRadius="4" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path x:Name="CheckMark" Width="10" Height="10" Stretch="Uniform" Fill="{StaticResource MenuForegroundBrush}" Data="M 0 5 L 3.2 8.2 L 9 0.8 L 10 1.8 L 3.2 10 L -1 5.8 Z" Visibility="Collapsed"/>
                    </Border>

                    <ContentPresenter
                        Grid.Column="1"
                        Margin="8,7,12,7"
                        VerticalAlignment="Center"
                        ContentSource="Header"
                        RecognizesAccessKey="True"/>

                    <TextBlock
                        x:Name="GestureText"
                        Grid.Column="2"
                        Margin="0,7,10,7"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource MenuSecondaryForegroundBrush}"
                        Text="{TemplateBinding InputGestureText}"/>

                    <Path
                        x:Name="SubmenuArrow"
                        Grid.Column="3"
                        Margin="0,0,6,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Fill="{StaticResource MenuSecondaryForegroundBrush}"
                        Data="M 0 0 L 5 4 L 0 8 Z"
                        Visibility="Collapsed"/>

                    <Popup
                        x:Name="PART_Popup"
                        AllowsTransparency="True"
                        Focusable="False"
                        IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                        Placement="Right"
                        PopupAnimation="Fade">
                        <Border
                            Margin="4,0,0,0"
                            Background="{StaticResource MenuBackgroundBrush}"
                            BorderBrush="{StaticResource MenuBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <ScrollViewer
                                CanContentScroll="True"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Disabled">
                                <StackPanel KeyboardNavigation.DirectionalNavigation="Cycle" Margin="6">
                                    <ItemsPresenter/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="Role" Value="SubmenuHeader">
                    <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="Role" Value="TopLevelHeader">
                    <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource MenuHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="CheckContainer" Property="Background" Value="{StaticResource MenuCheckedBrush}"/>
                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource MenuDisabledForegroundBrush}"/>
                    <Setter TargetName="GestureText" Property="Foreground" Value="{StaticResource MenuDisabledForegroundBrush}"/>
                    <Setter TargetName="SubmenuArrow" Property="Fill" Value="{StaticResource MenuDisabledForegroundBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{StaticResource MenuForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template" Value="{StaticResource DarkMenuItemTemplate}"/>
        </Style>
    </Application.Resources>
</Application>
