<Window x:Class="Binjyo.ShortcutHelp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Shortcut Help"
        Width="800"
        Height="600"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Margin="0,0,0,12"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="Shortcut Help"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="12"
                        Margin="0,0,0,12"
                        Background="#FFF4F4F4"
                        BorderBrush="#FFD0D0D0"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Global"/>
                        <TextBlock Margin="0,8,0,0"
                                   TextWrapping="Wrap">
                            <Run Text="Take screenshot: "/>
                            <Run x:Name="GlobalShortcutText"
                                 FontFamily="Consolas"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Padding="12"
                        Background="#FFF4F4F4"
                        BorderBrush="#FFD0D0D0"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="On a focused memo"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Action"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Text="Shortcut"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" FontWeight="SemiBold" Text="Notes"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" Text="Copy and close"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Ctrl+X"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,6,0,0" Text="Double-click also works."/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" Text="Copy"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Ctrl+C"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,0,0" Text="Save PNG"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="S"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,0,0" Text="Close memo"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Esc"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,0,0" Text="Resize smaller"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="D"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" Margin="0,6,0,0" Text="Ctrl + mouse wheel down also works."/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,6,0,0" Text="Resize larger"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="F"/>
                            <TextBlock Grid.Row="6" Grid.Column="2" Margin="0,6,0,0" Text="Ctrl + mouse wheel up also works."/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,6,0,0" Text="Reset size"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="`"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,6,0,0" Text="Rotate 90°"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="R"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,6,0,0" Text="Flip horizontally"/>
                            <TextBlock Grid.Row="9" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="H"/>

                            <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,6,0,0" Text="Flip vertically"/>
                            <TextBlock Grid.Row="10" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="V"/>

                            <TextBlock Grid.Row="11" Grid.Column="0" Margin="0,6,0,0" Text="Grayscale on/off"/>
                            <TextBlock Grid.Row="11" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="G"/>

                            <TextBlock Grid.Row="12" Grid.Column="0" Margin="0,6,0,0" Text="Binarization on/off"/>
                            <TextBlock Grid.Row="12" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="B"/>
                            <TextBlock Grid.Row="12" Grid.Column="2" Margin="0,6,0,0" Text="B + mouse wheel changes threshold."/>

                            <TextBlock Grid.Row="13" Grid.Column="0" Margin="0,6,0,0" Text="Quantization on/off"/>
                            <TextBlock Grid.Row="13" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Q"/>
                            <TextBlock Grid.Row="13" Grid.Column="2" Margin="0,6,0,0" Text="Q + mouse wheel changes number of levels."/>

                            <TextBlock Grid.Row="14" Grid.Column="0" Margin="0,6,0,0" Text="Opacity on/off"/>
                            <TextBlock Grid.Row="14" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="O"/>
                            <TextBlock Grid.Row="14" Grid.Column="2" Margin="0,6,0,0" Text="O + mouse wheel changes opacity."/>

                            <TextBlock Grid.Row="15" Grid.Column="0" Margin="0,6,0,0" Text="Hue map / color wheel"/>
                            <TextBlock Grid.Row="15" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="C / Shift"/>
                            <TextBlock Grid.Row="15" Grid.Column="2" Margin="0,6,0,0" Text="C toggles hue map. Hold Shift while hovering to show the color wheel." TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
