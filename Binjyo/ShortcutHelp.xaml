<Window x:Class="Binjyo.ShortcutHelp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Shortcut Help"
        Width="800"
        Height="700"
        MinWidth="520"
        MinHeight="420"
        Background="#111111"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Margin="0,0,0,12"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#FFF3F3F3"
                   Text="Shortcut Help"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="12"
                        Margin="0,0,0,12"
                        Background="#FF1E1E1E"
                        BorderBrush="#FF3C3C3C"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#FFF3F3F3"
                                   Text="Global"/>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#FFD6D6D6"
                                   TextWrapping="Wrap">
                            <Run Text="Take screenshot: "/>
                            <Run x:Name="GlobalShortcutText"
                                 Foreground="#FFFFFFFF"
                                 FontFamily="Consolas"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Padding="12"
                        Background="#FF1E1E1E"
                        BorderBrush="#FF3C3C3C"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#FFF3F3F3"
                                   Text="On a focused memo"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FFD6D6D6"/>
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Foreground="#FFF3F3F3" Text="Action"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Foreground="#FFF3F3F3" Text="Shortcut"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" FontWeight="SemiBold" Foreground="#FFF3F3F3" Text="Notes"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" Foreground="#FFD6D6D6" Text="Copy and close"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Foreground="#FFFFFFFF" FontFamily="Consolas" Text="X / Ctrl+X"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,6,0,0" Foreground="#FFD6D6D6" Text="Copies the current memo with drawing applied. Double-click also works. Hold Shift to use the original image only." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" Text="Copy"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="C / Ctrl+C"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Margin="0,6,0,0" Text="Copies the current memo with drawing applied. Hold Shift to use the original image only." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,0,0" Text="Save PNG"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="S"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Margin="0,6,0,0" Text="Saves the current image with drawing applied at original image size." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,0,0" Text="Save original PNG"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Shift+S"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Margin="0,6,0,0" Text="Saves the original image without drawing." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,0,0" Text="Close memo"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Esc"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,6,0,0" Text="Resize"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Ctrl + wheel"/>
                            <TextBlock Grid.Row="6" Grid.Column="2" Margin="0,6,0,0" Text="Wheel down makes the memo smaller. Wheel up makes it larger." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,6,0,0" Text="Reset size"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="`"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,6,0,0" Text="Rotate 90°"/>
                            <TextBlock Grid.Row="9" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="R"/>

                            <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,6,0,0" Text="Flip horizontally"/>
                            <TextBlock Grid.Row="10" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="F"/>

                            <TextBlock Grid.Row="11" Grid.Column="0" Margin="0,6,0,0" Text="Flip vertically"/>
                            <TextBlock Grid.Row="11" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Shift+F"/>

                            <TextBlock Grid.Row="12" Grid.Column="0" Margin="0,6,0,0" Text="Grayscale on/off"/>
                            <TextBlock Grid.Row="12" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="G"/>

                            <TextBlock Grid.Row="13" Grid.Column="0" Margin="0,6,0,0" Text="Binarization on/off"/>
                            <TextBlock Grid.Row="13" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="B"/>
                            <TextBlock Grid.Row="13" Grid.Column="2" Margin="0,6,0,0" Text="B + mouse wheel changes threshold."/>

                            <TextBlock Grid.Row="14" Grid.Column="0" Margin="0,6,0,0" Text="Quantization on/off"/>
                            <TextBlock Grid.Row="14" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Q"/>
                            <TextBlock Grid.Row="14" Grid.Column="2" Margin="0,6,0,0" Text="Q + mouse wheel changes number of levels."/>

                            <TextBlock Grid.Row="15" Grid.Column="0" Margin="0,6,0,0" Text="Opacity on/off"/>
                            <TextBlock Grid.Row="15" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="O"/>
                            <TextBlock Grid.Row="15" Grid.Column="2" Margin="0,6,0,0" Text="O + mouse wheel changes opacity."/>

                            <TextBlock Grid.Row="16" Grid.Column="0" Margin="0,6,0,0" Text="Hue map / color wheel"/>
                            <TextBlock Grid.Row="16" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="H / CapsLock"/>
                            <TextBlock Grid.Row="16" Grid.Column="2" Margin="0,6,0,0" Text="H toggles hue map. CapsLock toggles the color wheel display state while the mouse is over the memo." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="17" Grid.Column="0" Margin="0,6,0,0" Text="Move memo"/>
                            <TextBlock Grid.Row="17" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Arrow keys"/>
                            <TextBlock Grid.Row="17" Grid.Column="2" Margin="0,6,0,0" Text="Moves by 1 pixel. Hold to repeat and accelerate. This does not snap." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="18" Grid.Column="0" Margin="0,6,0,0" Text="Move connected memos"/>
                            <TextBlock Grid.Row="18" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Alt + drag / Arrow keys"/>
                            <TextBlock Grid.Row="18" Grid.Column="2" Margin="0,6,0,0" Text="Moves this memo together with all recursively overlapping or touching memos." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="19" Grid.Column="0" Margin="0,6,0,0" Text="Move memo faster"/>
                            <TextBlock Grid.Row="19" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Shift + Arrow keys"/>
                            <TextBlock Grid.Row="19" Grid.Column="2" Margin="0,6,0,0" Text="Multiplies the movement step by 10. Can be combined with Alt group move." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="20" Grid.Column="0" Margin="0,6,0,0" Text="Jump to next snap"/>
                            <TextBlock Grid.Row="20" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Ctrl + Arrow keys"/>
                            <TextBlock Grid.Row="20" Grid.Column="2" Margin="0,6,0,0" Text="Jumps to the next snappable position in that direction. With Alt, the connected memo group uses its bounding box." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="21" Grid.Column="0" Margin="0,6,0,0" Text="Resize mode"/>
                            <TextBlock Grid.Row="21" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="T"/>
                            <TextBlock Grid.Row="21" Grid.Column="2" Margin="0,6,0,0" Text="Shows corner resize markers and enables drag resizing from the corners." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="22" Grid.Column="0" Margin="0,6,0,0" Text="Toggle snapping temporarily"/>
                            <TextBlock Grid.Row="22" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Space + drag"/>
                            <TextBlock Grid.Row="22" Grid.Column="2" Margin="0,6,0,0" Text="Temporarily inverts the snap setting while moving or resizing." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="23" Grid.Column="0" Margin="0,6,0,0" Text="Focus memo under mouse"/>
                            <TextBlock Grid.Row="23" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Tab"/>
                            <TextBlock Grid.Row="23" Grid.Column="2" Margin="0,6,0,0" Text="Focuses the memo under the mouse, cycles through overlapping memos, or cycles all memos if the mouse is outside them." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="24" Grid.Column="0" Margin="0,6,0,0" Text="Resize snapping"/>
                            <TextBlock Grid.Row="24" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Space + drag"/>
                            <TextBlock Grid.Row="24" Grid.Column="2" Margin="0,6,0,0" Text="In resize mode, snapping follows the memo snap setting. Hold Space to temporarily invert it." TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="12"
                        Margin="0,12,0,0"
                        Background="#FF1E1E1E"
                        BorderBrush="#FF3C3C3C"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#FFF3F3F3"
                                   Text="In edit mode"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FFD6D6D6"/>
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Foreground="#FFF3F3F3" Text="Action"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Foreground="#FFF3F3F3" Text="Shortcut"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" FontWeight="SemiBold" Foreground="#FFF3F3F3" Text="Notes"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" Text="Exit edit mode"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Esc / Enter"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" Text="Brush tool"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Q"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,0,0" Text="Eraser tool"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="E"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Margin="0,6,0,0" Text="Removes the whole stroke that the eraser touches." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,0,0" Text="Draw / erase"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" Margin="0,6,0,0" Text="Drag with the left mouse button." TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,0,0" Text="Undo"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="Z / Ctrl+Z"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,6,0,0" Text="Brush size down / up"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,6,0,0" FontFamily="Consolas" Text="[ / ]"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,6,0,0" Text="Exit on focus loss"/>
                            <TextBlock Grid.Row="7" Grid.Column="2" Margin="0,6,0,0" Text="Other shortcuts and operations are disabled while editing." TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
